# Mend Unified Agent configuration for SCA-5589 regression test
# This config deliberately mirrors the conditions that trigger the bug:
#   1. python.ignorePipInstallErrors=true  — enables the fallback path
#   2. pip install will fail (bogus package in requirements.txt)
#   3. Per-line download fallback fires
# After the fix, transitive deps must still be reported under their parent.

apiKey=
wss.url=

# Python scanning
python.resolveDependencies=true
python.ignorePipInstallErrors=true
python.runPipenvPreStep=false
python.resolveHierarchyTree=true

# Project identification
projectName=pip-ignore-pip-install-errors-transitive-fix

# Offline mode off — scanner needs PyPI access for the per-line fallback
offline=false

# Resolve all file types
resolveAllDependencies=false
